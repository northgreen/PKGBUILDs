# Maintainer: ictye <northgreen2006 at qq dot com>
pkgname=deep-student-git
url='https://github.com/helixnow/deep-student'
pkgrel=1
pkgver=v0.9.31.r0.g3224cf2
pkgdesc='AI驱动的智能学习助手,Deep Student 是一款专为学生设计的AI驱动的智能学习助手。它利用先进的人工智能技术，帮助用户进行错题分析、知识点梳理和个性化学习，从而实现深度理解和高效学习。'
arch=('x86_64')
license=('AGPL-3.0-only')
depends=(
    'xz'
    'gtk3'
    'gdk-pixbuf2'
    'cairo'
    'glib2'
    'webkit2gtk-4.1'
    'libsoup3'
    'libgcc'
    'glibc'
    'bzip2'
)
makedepends=(
    'git'
    'cargo'
    'npm'
    'clang'
    'pkg-config'

    'protobuf'
)
source=(
    'deep-student::git+https://github.com/helixnow/deep-student.git#branch=main'
    'deep-student.png'
    'deep-student.desktop'
)

sha256sums=('SKIP'
    'bd0bdcdb69b6e502ae2700eebdfcede0b3465abdc3d8254720ffcb1f6d2cc13e'
    '158a3a0a3221940180409c6a79b9e3e08a64d4f56bc3a8da200132a9b984c8ae')

pkgver() {
    cd deep-student
    git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
    cd "$srcdir/deep-student"
    target="$CARCH-unknown-linux-gnu"

    # Already Config LTO at Cargo.toml
    CFLAGS="${CFLAGS//-flto=auto/}"
    CXXFLAGS="${CXXFLAGS//-flto=auto/}"

    # Init PKGCONFIG Environment Variables
    export PKG_CONFIG_LIBDIR="/does-not-exist:/usr/lib/pkgconfig:/usr/share/pkgconfig"
    export PKG_CONFIG_SYSTEM_INCLUDE_PATH="/usr/include"
    export PKG_CONFIG_SYSTEM_LIBRARY_PATH="/usr/lib:/lib"

    SHARP_IGNORE_GLOBAL_LIBVIPS=1 npm install

    npm run build

    node scripts/generate-version.mjs || true
    npm run tauri build -- --target "$target" --bundles deb --no-sign # If give no bundle,it will get an error

}

package() {
    target="$CARCH-unknown-linux-gnu"

    tauri_dir="$srcdir/deep-student/src-tauri"
    release_dir="$tauri_dir/target/$target/release"

    # base install
    install -D -m755 $release_dir/deep-student "$pkgdir"/usr/bin/deep-student
    install -D -m644 deep-student.png "$pkgdir"/usr/share/pixmaps/deep-student.png
    install -D -m644 deep-student.desktop "$pkgdir"/usr/share/applications/deep-student.desktop

    #license
    install -Dm644 "$srcdir/deep-student/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/AGPL-3.0.txt"
}
